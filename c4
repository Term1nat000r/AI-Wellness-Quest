workspace "LocalScript" "Компактная архитектура мультиагентной системы" {

    !identifiers hierarchical

    model {
        u = person "Разработчик / Пользователь" "Инициатор запроса и получатель кода"
        
        llm = softwareSystem "Ollama API" "Локальная модель (Qwen2 / Llama3)" "External"
        os = softwareSystem "Host OS" "Среда исполнения (Sandbox)" "External"

        ss = softwareSystem "LocalScript System" "Изолированный бэкенд" {
            
            group "Хранилища и Состояние" {
                db = container "SessionStorage" "История чатов и имена сессий" "SQLite" "Database"
                kb = container "Static Knowledge Base" "База MTS_LUA_EXAMPLES" "knowledge.py" "Database"
                state = container "Стейт классы" "Task, CodeResult" "In-memory" "Database"
            }
            
            group "Агентское ядро (Обработка)" {
                orchestrator = container "ORCHESTRATOR" "Центральный хаб управления" "orchestrator.py" "Hero"
                
                namer = container "Namer Agent" "Именование сессии по первому промпту" "namer.py" "Agent"
                clarifier = container "Clarifier Agent" "Уточнение требований" "clarifier.py" "Agent"
                generator = container "Generator Agent" "Синтез Lua-кода" "generator.py" "Agent"
                parser = container "Output Parser" "Извлечение полезной нагрузки" "Regex" "Agent"
                
                validator = container "Validator Agent" "LLM-анализ ошибок" "validator.py" "Agent"
                syntax = container "Syntax Checker" "Проверка в Host OS" "run_syntax_check" "Agent"
            }
            
            group "Интерфейсы и Шлюзы" {
                api = container "API Gateway" "Эндпоинт POST /generate" "main.py" "Gateway"
                contracts = container "Contracts Layer" "Pydantic валидация" "contracts.py" "Gateway"
                llmClient = container "Unified LLM Client" "OpenAI SDK Client" "llm_client.py" "Gateway"
            }
        }

        // --- ЛОГИКА ВЗАИМОДЕЙСТВИЯ ---
        
        // Хранилища (инвертированные связи — базы слева)
        ss.db -> ss.orchestrator "Лог сессии"
        ss.state -> ss.orchestrator "Стейт"
        ss.kb -> ss.generator "Примеры"
        
        // Основной поток
        u -> ss.api "Отправляет запрос"
        ss.api -> ss.contracts "Валидация"
        ss.contracts -> ss.orchestrator "Передача задачи"
        
        // Управление агентами (граф состояний)
        ss.orchestrator -> ss.namer "0. Именование (первый промпт)"
        ss.orchestrator -> ss.clarifier "1. Уточнение"
        ss.orchestrator -> ss.generator "2. Генерация"
        ss.orchestrator -> ss.validator "3. Верификация"
        ss.orchestrator -> ss.generator "Retry с фидбеком"
        
        // Возврат результата
        ss.orchestrator -> ss.api "Возврат результата"
        ss.api -> u "Выдача готового кода"
        
        // Generator: парсинг и LLM
        ss.generator -> ss.parser "Сырой ответ"
        ss.parser -> ss.orchestrator "Чистый код"
        
        // ВСЕ LLM-агенты ходят в Unified LLM Client
        ss.namer -> ss.llmClient "Запрос к LLM"
        ss.clarifier -> ss.llmClient "Запрос к LLM"
        ss.generator -> ss.llmClient "Запрос к LLM"
        ss.validator -> ss.llmClient "Запрос к LLM"
        
        // Validator: проверка синтаксиса
        ss.validator -> ss.syntax "Чек синтаксиса"
        ss.syntax -> os "Выполнение"
        ss.validator -> ss.orchestrator "Отчет об ошибках"
        
        // LLM Client → внешняя модель
        ss.llmClient -> llm "Инференс"
    }

    views {
        container ss "Compact_View" "Компактная горизонтальная архитектура" {
            include *
            
            autoLayout lr 60 40
        }

        styles {
            element "Element" {
                stroke #3A7EC2
                background #438DD5
                color #FFFFFF
                strokeWidth 1
                fontSize 18
                shape roundedbox
            }
            element "Person" {
                shape person
                background #1168BD
            }
            element "Database" {
                shape cylinder
            }
            element "Hero" {
                shape hexagon
                background #1168BD
                strokeWidth 5
                fontSize 28
            }
            element "External" {
                background #999999
                stroke #888888
            }
            
            element "Group:Интерфейсы и Шлюзы" {
                stroke #E67E22
                color #E67E22
                strokeWidth 2
            }
            element "Group:Агентское ядро (Обработка)" {
                stroke #2ECC71
                color #2ECC71
                strokeWidth 2
            }
            element "Group:Хранилища и Состояние" {
                stroke #9B59B6
                color #9B59B6
                strokeWidth 2
            }

            relationship "Relationship" {
                color #707070
                thickness 1
                fontSize 14
            }
        }
    }
}